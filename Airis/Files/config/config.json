{
  "system": {
    "websocket_port": 9000
  },
  "llm": {
    "temperature": 1.0,
    "max_tokens": 4096,
    "top_p": 1.0,
    "frequency_penalty": 0.0,
    "presence_penalty": 0.0,
    "tool_choice": "auto"
  },
  "tts": {
    "voice": "zh-CN-XiaoyiNeural",
    "pitch": "+0Hz",
    "rate": "+0%",
    "volume": "+0%"
  },
  "stt": {
    "local": false,
    "cloudflare_model": "@cf/openai/whisper-large-v3-turbo",
    "model": "turbo",
    "models_dir": "Files/models/whisper",
    "language": "zh",
    "prompt": "Zostime Airis",
    "temperature": 0,
    "best_of": 1,
    "beam_size": 5,
    "sample_rate": 16000,
    "vad_filter": true,
    "channels": 1,
    "chunk_size": 1024,
    "silence_threshold": 500,
    "silence_timeout": 1.0
  },
  "prompts": {
    "path": [
      "core/prompts/system.md",
      "core/prompts/personality.md",
      "core/prompts/memory.md",
      "core/prompts/runtime_state.md"
    ]
  },
  "memory": {
    "note": {
      "path": "Files/memories/note",
      "max_char": 256
    },
    "stm": {
      "limit": 20,
      "path": "Files/memories/short_term"
    },
    "ltm": {
      "limit": 20,
      "threshold": 0.7,
      "score_threshold": 0.3,
      "vector_store": {
        "provider": "chroma",
        "config": {
          "collection_name": "mem0",
          "path": "Files/memories/long_term"
        }
      },
      "embedder": {
        "provider": "huggingface",
        "config": {
          "model": "BAAI/bge-small-zh-v1.5",
          "path": "Files/models/embedder"
        }
      },
      "llm": {
        "provider": "openai",
        "config": {
          "temperature": 0.2,
          "max_tokens": 512,
          "top_p": 1.0,
          "frequency_penalty": 0,
          "presence_penalty": 0
        }
      },
      "history_db": {
        "provider": "sqlite",
        "config": {
          "path": "Files/memories/long_term"
        }
      }
    }
  },
  "logging": {
    "enabled": true,
    "level": "INFO",
    "console_level": "DEBUG",
    "llm_dir": "Files/logs/llm",
    "tts_dir": "Files/logs/tts",
    "stt_dir": "Files/logs/stt",
    "tools_dir": "Files/logs/tools",
    "memory_dir": "Files/logs/memory",
    "system_dir": "Files/logs/system",
    "max_file_size_mb": 10,
    "backup_count": 5
  },
  "cache": {
    "llm_dir": "Files/cache/llm",
    "tts_dir": "Files/cache/tts",
    "stt_dir": "Files/cache/stt",
    "memory_dir": "Files/cache/memory",
    "system_dir": "Files/cache/system"
  }
}