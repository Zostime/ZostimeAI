{
  "llm": {
    "temperature": 0.7,
    "max_tokens": 4096,
    "top_p": 1.0,
    "frequency_penalty": 0.0,
    "presence_penalty": 0.0
  },
  "tts": {
    "voice": "af_heart",
    "language": "zh"
  },
  "stt": {
    "model": "medium",
    "models_dir": "Files/models/whisper",
    "sample_rate": 16000,
    "channels": 1,
    "chunk_size": 1024,
    "silence_threshold": 500,
    "silence_timeout": 1.0
  },
  "memory": {
    "vector_store": {
      "provider": "chroma",
      "config": {
        "collection_name": "mem0",
        "path": "Files/memories"
      }
    },
    "embedder": {
      "provider": "huggingface",
      "config": {
        "model": "sentence-transformers/all-MiniLM-L6-v2"
      }
    },
    "llm": {
      "provider": "openai",
      "config": {
        "temperature": 0.2,
        "max_tokens": 512,
        "top_p": 1.0,
        "frequency_penalty": 0,
        "presence_penalty": 0
      }
    },
    "history_db": {
      "provider": "sqlite",
      "config": {
        "path": "Files/memories"
      }
    }
  },
  "logging": {
    "enabled": true,
    "level": "INFO",
    "llm_dir": "Files/logs/llm",
    "tts_dir": "Files/logs/tts",
    "stt_dir": "Files/logs/stt",
    "max_file_size_mb": 10,
    "backup_count": 5
  },
  "cache": {
    "llm_dir": "Files/cache/llm",
    "tts_dir": "Files/cache/tts",
    "stt_dir": "Files/cache/stt"
  }
}