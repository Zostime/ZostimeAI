{
  "llm": {
    "temperature": 0.7,
    "max_tokens": 4096,
    "top_p": 1.0,
    "frequency_penalty": 0.0,
    "presence_penalty": 0.0,
    "tool_choice": "auto"
  },
  "tts": {
    "voice": "af_heart",
    "language": "zh",
    "speed": 1.0
  },
  "stt": {
    "model": "medium",
    "models_dir": "Files/models/whisper",
    "prompt": "Zostime,Airis",
    "temperature": 0,
    "best_of": 1,
    "beam_size": 5,
    "sample_rate": 16000,
    "channels": 1,
    "chunk_size": 1024,
    "silence_threshold": 500,
    "silence_timeout": 1.0
  },
  "memory": {
    "stm": {
      "limit": 10,
      "path": "Files/memories/short_term"
    },
    "ltm": {
      "limit": 20,
      "threshold": 0.7,
      "vector_store": {
        "provider": "chroma",
        "config": {
          "collection_name": "mem0",
          "path": "Files/memories/long_term"
        }
      },
      "embedder": {
        "provider": "huggingface",
        "config": {
          "model": "BAAI/bge-small-zh-v1.5",
          "path": "Files/models/embedder"
        }
      },
      "llm": {
        "provider": "openai",
        "config": {
          "temperature": 0.2,
          "max_tokens": 512,
          "top_p": 1.0,
          "frequency_penalty": 0,
          "presence_penalty": 0
        }
      },
      "history_db": {
        "provider": "sqlite",
        "config": {
          "path": "Files/memories/long_term"
        }
      }
    }
  },
  "logging": {
    "enabled": true,
    "level": "INFO",
    "console_level": "DEBUG",
    "llm_dir": "Files/logs/llm",
    "tts_dir": "Files/logs/tts",
    "stt_dir": "Files/logs/stt",
    "tools_dir": "Files/logs/tools",
    "memory_dir": "Files/logs/memory",
    "max_file_size_mb": 10,
    "backup_count": 5
  },
  "cache": {
    "llm_dir": "Files/cache/llm",
    "tts_dir": "Files/cache/tts",
    "stt_dir": "Files/cache/stt",
    "memory_dir": "Files/cache/memory"
  }
}